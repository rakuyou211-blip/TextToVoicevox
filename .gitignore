# Python 仮想環境（各自 setup で作成するため配布しない）
venv/
venv_mac/

# Python キャッシュ
__pycache__/
*.pyc
*.pyo

# ユーザー個別の設定（初回起動時に自動生成される）
settings.json
settings.json.bak
last_text.txt

# 行単位の合成キャッシュ（自動生成・上限500MBでLRU削除）
voice_cache/

# pytest のキャッシュ
.pytest_cache/

# OS が生成するファイル
.DS_Store
Thumbs.db

# エディタ
.vscode/
.idea/
*.swp

# キャラ立ち絵（公式無料素材）はローカルのみ。公開リポジトリでの二次配布を避ける。
assets/立ち絵/*.png
